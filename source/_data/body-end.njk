{# Mermaid compatibility for legacy posts (old NexT exported mermaid as highlighted plaintext) #}
{%- if theme.mermaid.enable and config.mermaid.enable %}
  <script>
    // Convert legacy highlighted plaintext blocks (figure.highlight.plain) into
    // NexT's expected structure: <pre><code class="mermaid">...</code></pre>
    // IMPORTANT: run on `page:loaded` so it works with PJAX navigation.
    (function(){
      function normalize(txt) {
        txt = (txt || '');
        // drop leading line numbers that Hexo highlight may inject
        txt = txt.replace(/^\s*\d+\s*\n/gm, '');
        // common garbage: standalone numbers 1..n as lines
        txt = txt.replace(/^\s*\d+\s*$/gm, '');
        return txt.trim();
      }

      function isMermaid(txt) {
        return /^\s*(sequenceDiagram|graph\s+LR|graph\s+TD|graph\s+TB|graph\s+BT|gantt|classDiagram|stateDiagram|erDiagram|journey|pie)\b/m.test(txt);
      }

      function convertBlocks() {
        var pres = document.querySelectorAll('figure.highlight.plain .code pre');
        pres.forEach(function(pre){
          var txt = normalize(pre.innerText);
          if (!txt || !isMermaid(txt)) return;

          var figure = pre.closest('figure.highlight.plain');
          if (!figure || figure.__mermaidConverted) return;

          var outPre = document.createElement('pre');
          var outCode = document.createElement('code');
          outCode.className = 'mermaid';
          outCode.textContent = txt;
          outPre.appendChild(outCode);

          figure.parentNode.replaceChild(outPre, figure);
          figure.__mermaidConverted = true;
        });
      }

      function boot() {
        try { convertBlocks(); } catch (e) {}
      }

      // Works for both first load and PJAX page switches (NexT emits page:loaded)
      // Use CAPTURE phase to guarantee this runs before NexT's own mermaid handler.
      document.addEventListener('page:loaded', function(){
        boot();
        // run again shortly after in case the post body arrives a tick later
        setTimeout(boot, 200);
      }, true);

      // Also run once immediately in case this script loads after page:loaded
      // (e.g. browser cache / unusual timing)
      boot();

      // Fallback: if page:loaded isn't fired for some reason
      window.addEventListener('load', function(){
        boot();
        setTimeout(boot, 200);
      });
    })();
  </script>
{%- endif %}
